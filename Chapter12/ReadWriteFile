/*
 * Write a program to create a file named Exercise12_15.txt if it does not exist. 
 * Write 100 integers created randomly into the file using text I/O. Integers are separated by spaces in the file. 
 * Read the data back from the file and display the data in increasing order.
 * 
 * Author: Emily Rhodes
 * Date: 2026-03-10
 * Class: TESD 1800
 */

import java.io.File;
import java.util.Scanner;

public class ReadWriteFile {
    public static void main(String[] args) throws Exception {
        // Create a file if it does not exist
        File file = new File("Exercise12_15.txt");

        // Write to the file
        if (file.exists()) {
            System.out.println("File already exists.");
            System.exit(0);
        } 
        try (java.io.PrintWriter output = new java.io.PrintWriter(file)) {
            // Write 100 random integers to the file
            for (int i = 0; i < 100; i++) {
                int randomInt = (int) (Math.random() * 100);
                output.print(randomInt + " ");
            }
        }

        // Read from the file
        Scanner input = new Scanner(file);
        // Display the data in increasing order
        int[] numbers = new int[100];
        int index = 0;
        while (input.hasNextInt()) {
            numbers[index++] = input.nextInt();
        }
        java.util.Arrays.sort(numbers);
        for (int i = 0; i < index; i++) {
            System.out.print(numbers[i] + " ");
        }
        input.close();

    }
}
